FROM pgvector/pgvector:pg15

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y sudo curl lsb-release && \
    rm -rf /var/lib/apt/lists/*

# Stub qorven binary
RUN printf '#!/bin/sh\necho "qorven v0.0.0-test"\n' > /usr/local/bin/qorven-stub && \
    chmod +x /usr/local/bin/qorven-stub

COPY install.sh /install.sh

RUN pg_createcluster 15 main --start 2>/dev/null || true && \
    service postgresql start && \
    sudo -u postgres psql -c "SELECT 1" && \
    sudo -u postgres psql -c "CREATE EXTENSION IF NOT EXISTS vector;" 2>/dev/null || true

RUN service postgresql start && \
    QORVEN_BINARY=/usr/local/bin/qorven-stub bash /install.sh --yes --skip-service

# Verify config.toml
RUN test -f /etc/qorven/config.toml || (echo "MISSING config.toml" && exit 1)
RUN grep -q 'server\.tls' /etc/qorven/config.toml || (echo "WRONG tls nesting: $(cat /etc/qorven/config.toml)" && exit 1)
RUN grep -q 'mode' /etc/qorven/config.toml || (echo "MISSING tls mode" && exit 1)
RUN grep -q 'dsn' /etc/qorven/config.toml || (echo "MISSING dsn in config.toml" && exit 1)

# Verify database exists with pgvector
RUN service postgresql start && \
    sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='qorven'" | grep -q 1 || \
    (echo "DB missing" && exit 1)
RUN service postgresql start && \
    sudo -u postgres psql -d qorven -tAc "SELECT 1 FROM pg_extension WHERE extname='vector'" | grep -q 1 || \
    (echo "pgvector extension missing" && exit 1)

RUN echo "=== ALL CHECKS PASSED (Debian 12 / PG15) ===" && \
    echo "config.toml:" && cat /etc/qorven/config.toml
