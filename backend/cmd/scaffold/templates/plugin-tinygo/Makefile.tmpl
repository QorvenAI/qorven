# Build + upload targets for [[.Name]] (TinyGo).
#
# Requires tinygo >= 0.34. Install:
#   macOS:  brew install tinygo
#   Linux:  see https://tinygo.org/getting-started/install/linux/
#
# TinyGo produces a ~50 KiB .wasm instead of ~3.2 MiB with standard
# Go — critical in multi-tenant deployments with many plugins.

PLUGIN := [[.Name]]
GATEWAY ?= http://localhost:8080
TOKEN ?=

# -target wasi-p1   : use the WASI preview1 ABI (matches wazero host)
# -no-debug          : strip debug info for size
# -scheduler=none    : plugins are single-shot; no goroutines needed
# -gc=leaking        : short-lived process; GC overhead not worth it
TINYGO_FLAGS := -target wasi-p1 -no-debug -scheduler=none -gc=leaking

.PHONY: build upload clean check-tinygo

## build — compile to wasip1 Wasm via TinyGo.
build: check-tinygo
	tinygo build $(TINYGO_FLAGS) -o $(PLUGIN).wasm .
	@ls -lh $(PLUGIN).wasm
	@echo "Size target was ~50 KiB; anything over 200 KiB suggests GC/runtime isn't being elided."

check-tinygo:
	@command -v tinygo >/dev/null 2>&1 || { \
		echo "ERROR: tinygo is not installed. See https://tinygo.org/getting-started/install/"; \
		echo "Or switch to the standard-go template: qorven agent init --runtime go"; \
		exit 1; \
	}

## upload — POST the built .wasm to /v1/wasm-plugins.
upload: build
	@test -n "$(TOKEN)" || (echo "ERROR: set TOKEN=<admin-jwt>"; exit 1)
	curl -fsSL -X POST "$(GATEWAY)/v1/wasm-plugins" \
		-H "Authorization: Bearer $(TOKEN)" \
		-F "name=$(PLUGIN)" \
		-F "description=[[.Description]]" \
		-F "parameters=$$(cat parameters.json)" \
		-F "wasm=@$(PLUGIN).wasm" | jq .

clean:
	rm -f $(PLUGIN).wasm
