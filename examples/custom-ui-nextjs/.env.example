# Copy this to .env.local and edit.
#
# The HTTP base for Qorven's REST API. No trailing slash.
# Dev default matches backend/Makefile's `make run` listen address.
NEXT_PUBLIC_QORVEN_API_BASE=http://localhost:8080

# The WebSocket base. Usually the same host as the API, but with ws://
# or wss:// in place of http/https. Leave blank to derive automatically
# from NEXT_PUBLIC_QORVEN_API_BASE.
NEXT_PUBLIC_QORVEN_WS_BASE=
