# Qorven — environment variables
#
# Copy this file to .env and fill in the real values. Never commit .env
# to git — it's in .gitignore so accidentally running `git add .` is
# safe, but double-check before pushing.

# ─── Required ────────────────────────────────────────────────────────────

# PostgreSQL password for the local dev DB spun up by docker-compose.
# Pick anything; no production meaning. Generate with:
#   openssl rand -base64 24
QORVEN_DB_PASSWORD=

# ─── Gateway ports (optional, defaults shown) ────────────────────────────

# QORVEN_API_PORT=4200
# QORVEN_WEB_PORT=3000

# ─── Overrides (optional) ────────────────────────────────────────────────
#
# When set, these override the equivalent values in config.toml. They're
# useful for CI, secret managers (Vault, AWS SSM), or Docker Compose
# where config.toml would be rebuilt on every restart.

# QORVEN_POSTGRES_DSN=postgres://qorven:PASS@host:5432/qorven?sslmode=disable
# QORVEN_TOKEN=
# QORVEN_ENCRYPTION_KEY=
# QORVEN_HOST=127.0.0.1
# QORVEN_PORT=4200
# QORVEN_MEMORY_DIR=/var/lib/qorven/brain-memory
# QORVEN_SELF_REPO=/opt/qorven
# QORVEN_CONFIG=/etc/qorven/config.toml

# ─── Provider keys (optional — otherwise live in config.toml / the DB) ───

# QORVEN_OPENAI_API_KEY=
# QORVEN_ANTHROPIC_API_KEY=
# QORVEN_DEEPSEEK_API_KEY=
# QORVEN_GEMINI_API_KEY=
